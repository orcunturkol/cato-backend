TAILSCALE_IP=100.x.x.x
VITE_API_URL=http://100.x.x.x:5039
# Collector data dir on THIS host; mounted into the API container at the same
# absolute path so file-based ingestion messages resolve. Must match where the
# collector actually writes, e.g. /home/ubuntu/catoptric-data-collector/data
COLLECTOR_DATA_PATH=/path/to/catoptric-data-collector/data
